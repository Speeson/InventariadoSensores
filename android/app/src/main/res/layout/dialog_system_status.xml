<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="18dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_system_status_glow"
        android:orientation="vertical"
        android:padding="16dp"
        android:minHeight="240dp">

        <TextView
            android:id="@+id/tvSystemStatusTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="Estado del sistema"
            android:textColor="#ECF5FF"
            android:textSize="20sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/rowApi"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/ivApiIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/api" />

            <TextView
                android:id="@+id/tvApiLabel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:text="API"
                android:textColor="#E3EEFF"
                android:textSize="16sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/ivApiStatus"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_check_green" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/rowDb"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/ivDbIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/database" />

            <TextView
                android:id="@+id/tvDbLabel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:text="Base de datos"
                android:textColor="#E3EEFF"
                android:textSize="16sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/ivDbStatus"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_check_green" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/rowRedis"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/ivRedisIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/redis" />

            <TextView
                android:id="@+id/tvRedisLabel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:text="Redis"
                android:textColor="#E3EEFF"
                android:textSize="16sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/ivRedisStatus"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_check_green" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/rowCelery"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/ivCeleryIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/celery" />

            <TextView
                android:id="@+id/tvCeleryLabel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:text="Celery"
                android:textColor="#E3EEFF"
                android:textSize="16sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/ivCeleryStatus"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_check_green" />
        </LinearLayout>

        <Button
            android:id="@+id/btnCloseSystemStatus"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:layout_gravity="end"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_button_soft_purple"
            android:backgroundTint="@null"
            android:gravity="center"
            android:includeFontPadding="false"
            android:minWidth="0dp"
            android:paddingHorizontal="16dp"
            android:text="Cerrar"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="13sp"
            android:textStyle="bold" />

    </LinearLayout>
</FrameLayout>
