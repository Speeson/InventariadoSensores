<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_liquid_popup_card"
    android:orientation="vertical"
    android:padding="16dp">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="4dp">

        <TextView
            android:id="@+id/tvUrgentAlertsTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:text="Alertas importantes"
            android:textColor="@color/urgent_popup_title"
            android:textSize="20sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/btnUrgentAlertsClose"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:layout_gravity="end|center_vertical"
            android:background="@drawable/bg_liquid_button"
            android:backgroundTint="@null"
            android:padding="7dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_close_red"
            android:tint="@null"
            app:backgroundTint="@null" />
    </FrameLayout>

    <TextView
        android:id="@+id/tvUrgentAlertsHint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Desliza a izquierda o derecha para descartarlas solo de esta bandeja."
        android:textColor="@color/liquid_popup_hint"
        android:textSize="13sp" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="420dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_liquid_input">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvUrgentAlerts"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:padding="10dp" />

        <TextView
            android:id="@+id/tvUrgentAlertsEmpty"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:paddingLeft="20dp"
            android:paddingRight="20dp"
            android:text="No hay alertas prioritarias ahora mismo"
            android:textColor="@color/liquid_popup_text"
            android:textSize="14sp"
            android:visibility="gone" />
    </FrameLayout>

    <ImageButton
        android:id="@+id/btnUrgentAlertsClearAll"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="18dp"
        android:background="@drawable/bg_liquid_button_danger"
        android:contentDescription="Descartar todas las alertas visibles"
        android:padding="10dp"
        android:scaleType="centerInside"
        android:src="@drawable/glass_x"
        android:tint="@null" />

</LinearLayout>

