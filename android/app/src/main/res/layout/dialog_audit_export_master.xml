<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="340dp"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_liquid_popup_card"
    android:orientation="vertical"
    android:padding="16dp">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="Exportar auditoria"
            android:textColor="@color/liquid_popup_title"
            android:textSize="20sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/btnAuditExportDialogClose"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:layout_gravity="end|center_vertical"
            android:background="@drawable/bg_liquid_button"
            android:backgroundTint="@null"
            android:contentDescription="Cerrar"
            android:padding="7dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_close_red"
            app:backgroundTint="@null" />
    </FrameLayout>

    <Button
        android:id="@+id/btnExportAuditJson"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_liquid_button_pressable"
        android:backgroundTint="@null"
        android:text="Exportar a JSON"
        android:textAllCaps="false"
        android:textColor="@color/liquid_popup_button_text"
        android:textStyle="bold"
        app:backgroundTint="@null" />

    <Button
        android:id="@+id/btnExportAuditCsv"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_liquid_button_pressable"
        android:backgroundTint="@null"
        android:text="Exportar a CSV"
        android:textAllCaps="false"
        android:textColor="@color/liquid_popup_button_text"
        android:textStyle="bold"
        app:backgroundTint="@null" />

    <Button
        android:id="@+id/btnExportAuditText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_liquid_button_pressable"
        android:backgroundTint="@null"
        android:text="Exportar a Texto"
        android:textAllCaps="false"
        android:textColor="@color/liquid_popup_button_text"
        android:textStyle="bold"
        app:backgroundTint="@null" />

</LinearLayout>
