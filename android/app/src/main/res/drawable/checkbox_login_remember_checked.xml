<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <size
                android:width="18dp"
                android:height="18dp" />
            <corners android:radius="5dp" />
            <solid android:color="#5A6E86" />
            <stroke
                android:width="1.5dp"
                android:color="#C8FFFFFF" />
        </shape>
    </item>

    <item
        android:width="18dp"
        android:height="18dp"
        android:gravity="center"
        android:drawable="@drawable/ic_checkbox_login_tick" />
</layer-list>
