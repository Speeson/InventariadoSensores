<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="36dp" />
            <gradient
                android:angle="270"
                android:endColor="#12FFFFFF"
                android:startColor="#2EFFFFFF" />
            <stroke
                android:width="1dp"
                android:color="#70F2F6FF" />
        </shape>
    </item>
    <item android:left="18dp" android:top="14dp" android:right="18dp" android:bottom="430dp">
        <shape android:shape="rectangle">
            <corners android:radius="28dp" />
            <gradient
                android:angle="90"
                android:endColor="#00FFFFFF"
                android:startColor="#26FFFFFF" />
        </shape>
    </item>
    <item android:left="22dp" android:top="22dp" android:right="22dp" android:bottom="22dp">
        <shape android:shape="rectangle">
            <corners android:radius="30dp" />
            <stroke
                android:width="1dp"
                android:color="#1EFFFFFF" />
        </shape>
    </item>
</layer-list>
